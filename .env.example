# Google Sheets API Configuration
# To use real Google Sheets, follow these steps:
# 1. Go to Google Cloud Console (https://console.cloud.google.com/)
# 2. Create a new project and enable "Google Sheets API"
# 3. Create a Service Account and download the JSON key
# 4. Copy the "client_email" and "private_key" from the JSON file
# 5. Create a Google Sheet and share it with the "client_email"
# 6. Copy the Spreadsheet ID from the URL (e.g., https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit)

GOOGLE_SHEETS_CLIENT_EMAIL=
GOOGLE_SHEETS_PRIVATE_KEY=
GOOGLE_SHEETS_SPREADSHEET_ID=
